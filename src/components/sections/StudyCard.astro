---
import { shuffleArray } from "../../lib/utils";
import { PROFILE } from "../../content/profileData";
import { GraduationCap, ExternalLink, Award } from "lucide-react";

const iconMap = {
  graduation: GraduationCap,
  award: Award,
} as const;

shuffleArray(PROFILE.studies)
---

<div class="mt-2 space-y-2.5 animate-appear">
  {
    PROFILE.studies.map((study) => {
      const Component = study.link ? 'a' : 'div';
      const linkProps = study.link ? { href: study.link, target: "_blank", rel: "noopener noreferrer" } : {};
      const Icon = iconMap[study.icon as keyof typeof iconMap] ?? GraduationCap;

      return (
        <Component
          class="relative block rounded-lg border border-muted-foreground/20 bg-muted/30 px-3 py-2.5 transition-all hover:border-primary/50 hover:bg-muted/50 hover:shadow-sm"
          {...linkProps}
        >
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0">
              <div class="rounded-full bg-primary/10 p-1.5">
                <Icon className="h-4 w-4 text-primary" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-1.5">
                <h4 class="text-sm font-semibold text-foreground leading-tight truncate">
                  {study.title}
                </h4>
                {study.link && (
                  <ExternalLink className="h-3.5 w-3.5 text-muted-foreground flex-shrink-0" />
                )}
              </div>
              <p class="text-xs text-muted-foreground mt-0.5">
                {study.institution}
              </p>
            </div>
          </div>
        </Component>
      );
    })
  }
</div>
