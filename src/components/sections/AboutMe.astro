---
import { getAndGroupUniqueTags } from "../../lib/utils";
import { PROFILE } from "../../content/profileData";
import { useTranslations, getLangPrefix } from "../../i18n/utils";
import type { Language } from "../../i18n/ui";

interface Props {
  lang?: Language
}

const { lang = 'en' } = Astro.props
const t = useTranslations(lang)
const prefix = getLangPrefix(lang)

const tagsMap = await getAndGroupUniqueTags();
const skills = PROFILE.skills;
---

<div class="flex flex-col gap-2 animate-appear">
  <p class="text-sm font-light mb-1">
    {t('about.intro')}
  </p>

  <p class="text-md mb-1 font-medium">
    {t('about.headLine2')}
  </p>

  <hr/>

  <p class="text-sm font-light">
    {t('about.technologies')}
  </p>
  <ul class="list-inside list-disc">
    {
      skills.map((skill) => {
        if (tagsMap.has(skill)) {
          return (
            <li>
              <span>{skill}</span>
            </li>
          )
        } else {
          return (
            <li>
              <span>{skill}</span>
            </li>
          )
        }
      })
    }
  </ul>

  <p class="text-sm font-light">
    {t('about.exploreMore')} <a href={`${prefix}/projects`} class="underline hover:font-bold">{t('about.projects')}</a> {t('about.and')} <a href={`${prefix}/experiences`} class="underline hover:font-bold">{t('about.experiences')}</a>.
  </p>
</div>
