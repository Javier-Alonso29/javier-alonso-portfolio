---
import { getCollection } from "astro:content";
import { Button } from '../ui/button'
import { formateLocalDate } from "../../lib/utils";
import { useTranslations, getLangPrefix } from "../../i18n/utils";
import type { Language } from "../../i18n/ui";

interface Props {
  lang?: Language
}

const { lang = 'en' } = Astro.props
const t = useTranslations(lang)
const prefix = getLangPrefix(lang)

let posts = await getCollection('posts');

posts = posts.sort((a, b) => {
  return new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime();
});
posts = posts.slice(0, 2);
---

<div class="mt-2 space-y-4">
  {posts.length === 0 ? (
    <div class="flex flex-col items-center justify-center py-6 text-center space-y-3 rounded-lg">
      <div class="space-y-1">
        <div class="flex items-center justify-center gap-2">
          <span class="text-3xl"></span>
          <p class="text-base font-medium">{t('blog.noPosts')}</p>
        </div>
        <p class="text-sm text-muted-foreground">
          {t('blog.noPostsDesc')}
        </p>
      </div>
    </div>
  ) : (
    <>
      {posts.map((post) => (
        <div>
          <h3 class="text-lg font-semibold text-primary">
            <a href={`${prefix}/posts/${post.slug}`} class="hover:underline line-clamp-2">
              {post.data.title}
            </a>
          </h3>
          <p class="text-sm line-clamp-2">
            {post.data.description}
          </p>
          <p class="text-sm text-gray-600">
            {formateLocalDate(post.data.startDate)} {post.data?.endDate ? '- ' + formateLocalDate(post.data.endDate) : ''}
          </p>
        </div>
      ))}
      <a href={`${prefix}/posts`}>
        <Button variant="link" className="pl-0">{t('common.viewMore')}</Button>
      </a>
    </>
  )}
</div>
