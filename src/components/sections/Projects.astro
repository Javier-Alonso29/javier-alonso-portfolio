---
import { getCollection } from "astro:content";
import { Button } from '../ui/button'
import { formateLocalDate } from "../../lib/utils";
import { useTranslations, getLangPrefix } from "../../i18n/utils";
import type { Language } from "../../i18n/ui";

interface Props {
  lang?: Language
}

const { lang = 'en' } = Astro.props
const t = useTranslations(lang)
const prefix = getLangPrefix(lang)

let projects = await getCollection('projects');

projects.sort((a: any, b: any) => {
  return new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime();
});

projects = projects.slice(0, 3);
---

<div class="mt-2 space-y-4">
  {projects.length === 0 ? (
    <div class="flex flex-col items-center justify-center py-6 text-center space-y-3 rounded-lg">
      <span class="text-3xl">🚧</span>
      <div class="space-y-1">
        <p class="text-base font-medium">{t('projects.noProjects')}</p>
        <p class="text-sm text-muted-foreground">{t('projects.noProjectsDesc')}</p>
      </div>
    </div>
  ) : (
    <>
      {projects.slice(0, 3).map((project) => (
        <div>
          <h3 class="text-lg font-semibold text-primary">
            <a href={`${prefix}/projects/${project.slug}`} class="hover:underline">
              {project.data.title}
            </a>
          </h3>
          <p class="text-sm">
            {project.data.description}
          </p>
          <p class="text-sm text-gray-600">
            {formateLocalDate(project.data.startDate)} {project.data?.endDate ? '- ' + formateLocalDate(project.data.endDate) : ''}
          </p>
        </div>
      ))}
      <a href={`${prefix}/projects`}>
        <Button variant="link" className="pl-0">{t('common.viewMore')}</Button>
      </a>
    </>
  )}
</div>
