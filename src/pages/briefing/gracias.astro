---
// src/pages/briefing/gracias.astro
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Briefing recibido — Javier Alonso"
  description="Tu briefing fue recibido correctamente. Me pondré en contacto contigo en menos de 24 horas."
>
  <main class="flex min-h-[80vh] flex-auto flex-col items-center justify-center w-full p-4 max-w-screen-lg">
    <div class="flex flex-col items-center text-center max-w-md gap-6">

      <!-- Icono de éxito -->
      <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-8 h-8 text-primary"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <!-- Título -->
      <div class="space-y-2">
        <h1 class="text-3xl font-semibold tracking-tight text-foreground">
          ¡Briefing recibido!
        </h1>
        <p class="text-muted-foreground leading-relaxed">
          Gracias por compartir los detalles de tu proyecto. Revisaré tu información
          y me pondré en contacto contigo en un plazo no mayor a
          <strong class="text-foreground font-medium">24 horas</strong>.
        </p>
      </div>

      <!-- Qué sigue -->
      <div class="w-full rounded-lg p-5 m-5 text-left space-y-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">
          ¿Qué sigue?
        </p>
        <ul class="space-y-2.5">
          {[
            "Revisaré los detalles de tu proyecto con atención",
            "Prepararé una propuesta personalizada con tiempos y costos",
            "Me pondré en contacto por el correo o WhatsApp que proporcionaste",
          ].map((step, i) => (
            <li class="flex items-start gap-3 text-sm text-foreground/80">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-primary/10 text-primary text-xs font-semibold flex items-center justify-center mt-0.5">
                {i + 1}
              </span>
              {step}
            </li>
          ))}
        </ul>
      </div>

      <!-- Acciones -->
      <div class="flex flex-col sm:flex-row gap-3 w-full">
        <a
          href="/"
          class="flex-1 text-center bg-primary hover:bg-primary/90 active:scale-95 text-primary-foreground text-sm font-medium px-6 py-3 rounded-lg transition-all duration-150"
        >
          Volver al inicio
        </a>
        <a
          href="/briefing"
          class="flex-1 text-center border border-border hover:bg-muted active:scale-95 text-foreground text-sm font-medium px-6 py-3 rounded-lg transition-all duration-150"
        >
          Enviar otro briefing
        </a>
      </div>

    </div>
  </main>
</BaseLayout>
