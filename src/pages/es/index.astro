---
import BaseLayout from '../../layouts/BaseLayout.astro'
import IntroCard from '../../components/sections/IntroCard.astro'
import AboutMe from '../../components/sections/AboutMe.astro'
import Card from '../../components/Card.astro'
import TimeZoneCard from '../../components/sections/TimeZoneCard.astro'
import ExperienceCard from '../../components/sections/ExperienceCard.astro'
import Projects from '../../components/sections/Projects.astro'
import StudyCard from '../../components/sections/StudyCard.astro'
import { PROFILE } from "../../content/profileData";
import BlogCard from '../../components/sections/BlogCard.astro'
import { useTranslations } from '../../i18n/utils'

const lang = 'es'
const t = useTranslations(lang)
const SITE = PROFILE.site
---

<BaseLayout
  title={SITE.SEO.title}
  description={SITE.SEO.description}
  lang={lang}
>
  <main
    transition:animate="fade"
    class="relative m-auto grid w-full max-w-6xl gap-2 overflow-hidden p-2 sm:gap-2 sm:p-4 md:grid-cols-2 md:gap-3 md:p-6 lg:grid-cols-12 lg:gap-4"
  >
    <Card colSpan="lg:col-span-9 md:col-span-2" rowSpan="md:row-span-1 lg:row-span-4">
      <IntroCard lang={lang} />
    </Card>
    <Card
      colSpan="lg:col-span-3 md:col-span-2"
      rowSpan="md:row-span-2 lg:row-span-7"
      title={t('home.aboutMe')}
    >
      <AboutMe lang={lang} />
    </Card>

    <Card colSpan="lg:col-span-9 md:col-span-2" rowSpan="md:row-span-2 lg:row-span-3" title={t('home.experiences')}>
      <ExperienceCard lang={lang} />
    </Card>

    <Card colSpan="lg:col-span-6 md:col-span-1" rowSpan="md:row-span-3 lg:row-span-4" title={t('home.projects')}>
      <Projects lang={lang} />
    </Card>

    <Card colSpan="md:col-span-1 lg:col-span-6" rowSpan="md:row-span-1 lg:row-span-4" title={t('home.blogPosts')}>
      <BlogCard lang={lang} />
    </Card>

    <Card colSpan="lg:col-span-3 md:col-span-1" rowSpan="md:row-span-1 lg:row-span-2" title={t('home.yourTime')}>
      <TimeZoneCard/>
    </Card>
    <Card colSpan="lg:col-span-3 md:col-span-1" rowSpan="md:row-span-1 lg:row-span-2" title={t('home.myTime')}>
      <TimeZoneCard timezone={PROFILE.timezone} />
    </Card>

    <Card colSpan="md:col-span-1 lg:col-span-6" rowSpan="md:row-span-2 lg:row-span-2" title={t('home.education')}>
      <StudyCard/>
    </Card>

    <Card colSpan="md:col-span-1 lg:col-span-12" rowSpan="md:row-span-2 lg:row-span-1" title={t('home.connect')}>
      <div class="flex flex-col h-full w-full justify-center items-center gap-4">
        <p class="text-center text-sm">
          {t('home.connectDesc')}
        </p>

        <div class="flex flex-wrap gap-4 justify-center items-center">
          <a href={PROFILE.links.twitter}
             class="flex items-center gap-2 px-4 py-2 rounded-lg bg-muted/50 hover:bg-primary/10 border border-muted-foreground/10 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
            </svg>
            <span class="font-medium group-hover:text-primary transition-colors">Twitter DM</span>
          </a>

          <a href={PROFILE.links.github}
             class="flex items-center gap-2 px-4 py-2 rounded-lg bg-muted/50 hover:bg-primary/10 border border-muted-foreground/10 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
            <span class="font-medium group-hover:text-primary transition-colors">Github</span>
          </a>

          <a href={PROFILE.links.linkedin}
             class="flex items-center gap-2 px-4 py-2 rounded-lg bg-muted/50 hover:bg-primary/10 border border-muted-foreground/10 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect width="4" height="12" x="2" y="9"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
            <span class="font-medium group-hover:text-primary transition-colors">LinkedIn</span>
          </a>
        </div>

        <p class="text-center text-xs text-muted-foreground mt-2">
          {t('home.connectResponse')}
        </p>
      </div>
    </Card>

  </main>
</BaseLayout>
